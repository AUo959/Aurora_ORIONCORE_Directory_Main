{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/aurora_confidence_record.schema.json",
  "title": "Aurora Confidence Audit Record",
  "description": "Audit-layer confidence metadata for concrete Aurora conclusions, analyses, predictions, and recommendations.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_type": {
      "const": "confidence_assessment"
    },
    "assessment_id": {
      "type": "string",
      "pattern": "^aurora\\.confidence\\.[A-Za-z0-9_.:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "tool": {
      "const": "aurora_confidence_audit"
    },
    "authority_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "type": "string",
          "pattern": "^aurora\\.claim\\.[A-Za-z0-9_.:-]+$"
        },
        "claim_type": {
          "type": "string",
          "enum": [
            "conclusion",
            "analysis",
            "prediction",
            "recommendation"
          ]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "type": "string",
          "enum": [
            "internal",
            "user_facing",
            "background",
            "receipt_only"
          ]
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "subject_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "authority_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "receipt_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncertainty_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradiction_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolution_policy_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "claim_id",
        "claim_type",
        "text",
        "producer",
        "visibility",
        "subject_refs",
        "authority_refs",
        "evidence_refs",
        "receipt_refs",
        "assumptions",
        "uncertainty_factors",
        "contradiction_refs"
      ]
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "band": {
          "type": "string",
          "enum": [
            "high",
            "substantial",
            "limited",
            "low",
            "unsupported"
          ]
        },
        "evidence_level": {
          "type": "string",
          "enum": [
            "verified_artifact",
            "direct_observation",
            "deterministic_check",
            "corroborated_inference",
            "inference",
            "projection",
            "speculation",
            "unsupported"
          ]
        },
        "score_source": {
          "type": "string",
          "enum": [
            "explicit_score",
            "rubric_default"
          ]
        },
        "scoring_method": {
          "const": "aurora_confidence_audit_v1"
        },
        "calibration_profile": {
          "type": "string",
          "minLength": 1
        },
        "calibration_adjustment": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "adjustments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "code": {
                "type": "string",
                "minLength": 1
              },
              "delta": {
                "type": "number",
                "minimum": -1,
                "maximum": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "code",
              "delta",
              "reason"
            ]
          }
        }
      },
      "required": [
        "score",
        "threshold",
        "band",
        "evidence_level",
        "score_source",
        "scoring_method",
        "calibration_profile",
        "calibration_adjustment",
        "adjustments"
      ]
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires_user_alert": {
          "type": "boolean"
        },
        "alert_level": {
          "type": "string",
          "enum": [
            "none",
            "notice",
            "warning",
            "critical"
          ]
        },
        "alert_reason": {
          "type": "string",
          "enum": [
            "meets_threshold",
            "confidence_below_threshold"
          ]
        },
        "user_facing_message": {
          "type": [
            "string",
            "null"
          ]
        },
        "recommended_next_action": {
          "type": "string",
          "minLength": 1
        },
        "run_mode": {
          "type": "string",
          "minLength": 1
        },
        "live_runtime_execution": {
          "const": false
        },
        "nested_repo_mutation": {
          "const": false
        }
      },
      "required": [
        "requires_user_alert",
        "alert_level",
        "alert_reason",
        "recommended_next_action",
        "run_mode",
        "live_runtime_execution",
        "nested_repo_mutation"
      ]
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "assessment_id",
    "created_at",
    "tool",
    "authority_refs",
    "claim",
    "confidence",
    "audit"
  ]
}
