{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/aurora_vector_index.schema.json",
  "title": "Aurora Vector Index",
  "description": "Compatibility-first schema for recovered Aurora vector index registries used by the QEM / THREADCORE deploy lineage.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "default": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]*$"
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_:.\\-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "active",
              "release",
              "sandbox",
              "lockpoint",
              "meta"
            ]
          },
          "rituals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "bundle": {
            "type": "string",
            "pattern": "^.+\\.zip$"
          },
          "ethics_protocol": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.:\\-]+$"
          },
          "exported": {
            "type": "boolean"
          },
          "anchored_glyphs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "manifest_file": {
            "type": "string",
            "pattern": "^.+\\.json$"
          },
          "linked_threads": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "required": [
          "code",
          "description",
          "type"
        ]
      }
    }
  },
  "required": [
    "default",
    "vectors"
  ]
}
