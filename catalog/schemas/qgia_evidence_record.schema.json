{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/qgia_evidence_record.schema.json",
  "title": "QGIA Evidence Record",
  "description": "Append-only live evidence intake record for the QGIA closed learning loop.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "record_type": {
      "const": "evidence"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^qgia\\.evidence\\.[A-Za-z0-9_.:-]+$"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "topic_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "entity_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]+$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "osint",
            "sigint",
            "humint",
            "geoint",
            "masint",
            "manual",
            "derived",
            "model"
          ]
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "provenance_uri": {
          "type": "string",
          "minLength": 1
        },
        "reliability_assessment": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "source_id",
        "kind"
      ]
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "novelty_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": [
        "summary",
        "confidence"
      ]
    },
    "ingest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "manual",
            "pipeline",
            "import",
            "extraction"
          ]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{8,128}$"
        }
      },
      "required": [
        "producer",
        "method"
      ]
    },
    "resolution_state": {
      "type": "string",
      "enum": [
        "open",
        "linked",
        "superseded",
        "promoted"
      ]
    },
    "derived_from": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^qgia\\.evidence\\.[A-Za-z0-9_.:-]+$"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "schema_version",
    "record_type",
    "evidence_id",
    "observed_at",
    "ingested_at",
    "topic_refs",
    "source",
    "claim",
    "ingest",
    "resolution_state"
  ]
}

