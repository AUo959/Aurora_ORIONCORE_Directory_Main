#!/bin/sh
# Aurora dev kit pre-push gate.
# Blocks a push when a *required* tool in catalog/dev_toolkit_manifest.json is
# missing or broken (audit status BLOCKED). Optional-tool warnings do not block.
# Emergency bypass: git push --no-verify
set -eu

ROOT="$(git rev-parse --show-toplevel)"

echo "[pre-push] Auditing dev toolkit (required tools)..."
report="$(python3 "$ROOT/tools/aurora_devkit.py" --fail-on-blocker 2>&1)" && rc=0 || rc=$?

if [ "$rc" -eq 0 ]; then
    echo "[pre-push] Dev toolkit OK."
    exit 0
fi

echo "[pre-push] BLOCKED — a required dev tool is missing or broken:" >&2
echo "$report" >&2
echo "[pre-push] Fix the blocker(s) above, or bypass with: git push --no-verify" >&2
exit 1
