{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurora.local/schemas/command-intent-envelope.schema.json",
  "title": "Aurora Command Intent Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "raw_text",
    "intent_type",
    "grammar_family",
    "validation_status",
    "run_mode",
    "execution_scope",
    "live_runtime_execution",
    "simulation_status",
    "runtime_handler_verified",
    "gumas_mutation_auth_required",
    "gumas_mutation_auth_status",
    "gumas_mutation_auth_refs",
    "execution_status",
    "target_repo",
    "recommended_next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "raw_text": {
      "type": "string",
      "minLength": 1
    },
    "normalized_text": {
      "type": ["string", "null"]
    },
    "intent_type": {
      "type": "string",
      "enum": [
        "parse",
        "normalize",
        "validate",
        "explain",
        "mesh_route_map",
        "execute_request",
        "background_handoff"
      ]
    },
    "grammar_family": {
      "type": "string",
      "enum": [
        "aurora_symbolic_command",
        "mesh_router",
        "command_router",
        "ordinary_prose",
        "unknown"
      ]
    },
    "ast_shape": {
      "type": ["string", "null"],
      "enum": [
        "command_invocation",
        "command_sequence",
        "range_chain",
        "mesh_route",
        "unknown",
        "none",
        null
      ]
    },
    "command_heads": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "range_edges": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "end": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        }
      }
    },
    "arguments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "kind"],
        "properties": {
          "name": {
            "type": ["string", "null"]
          },
          "value": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["positional", "keyword"]
          }
        }
      },
      "default": []
    },
    "modifier": {
      "type": ["string", "null"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "valid",
        "valid_with_warnings",
        "invalid",
        "not_validated",
        "not_applicable"
      ]
    },
    "validation_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning"]
          },
          "message": {
            "type": "string"
          },
          "head": {
            "type": ["string", "null"]
          }
        }
      },
      "default": []
    },
    "run_mode": {
      "type": "string",
      "enum": [
        "parse_only",
        "mesh_route_map",
        "background_handoff",
        "blocked_execution_request",
        "in_process_simulation",
        "not_applicable"
      ],
      "default": "parse_only"
    },
    "execution_scope": {
      "type": "string",
      "enum": [
        "none",
        "blocked_pending_runtime_verification",
        "in_process_simulation",
        "live_runtime",
        "not_applicable"
      ],
      "default": "none"
    },
    "live_runtime_execution": {
      "type": "boolean",
      "default": false
    },
    "simulation_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "blocked",
        "completed",
        "failed"
      ],
      "default": "not_applicable"
    },
    "runtime_handler_verified": {
      "type": "boolean"
    },
    "runtime_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "gumas_mutation_auth_required": {
      "type": "boolean",
      "default": false
    },
    "gumas_mutation_auth_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "required_not_verified",
        "verified"
      ],
      "default": "not_applicable"
    },
    "gumas_mutation_auth_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "not_requested",
        "blocked_pending_verification",
        "ready_for_explicit_approval",
        "executed",
        "failed",
        "not_applicable"
      ]
    },
    "target_repo": {
      "type": ["string", "null"]
    },
    "authority_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "recommended_next_action": {
      "type": "string"
    },
    "receipt_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
