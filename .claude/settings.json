{
  "enabledPlugins": {
    "codacy-skills@codacy": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/session_stop_hook.py session-start",
            "statusMessage": "Session start: orphan check + auto-claim"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 tools/session_stop_hook.py"
          }
        ]
      }
    ]
  }
}
